   "source": [
    "### Max depth binary tree\n",
    "- base case: if current node is empty, return 0\n",
    "- return 1 plus the max between the left node function call and right node function call"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "1bf34b89",
   "metadata": {},
   "outputs": [],
   "source": [
    "def max_depth(root):\n",
    "    if not root:\n",
    "        return 0\n",
    "    return 1 + max(max_depth(root.left), max_depth(root.right))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "f96f38e8",
   "metadata": {},
   "outputs": [],
